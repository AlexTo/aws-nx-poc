{
  "name": "@aws-nx-poc/trpc",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/trpc/src",
  "projectType": "library",
  "tags": [],
  "metadata": {
    "generator": "ts#trpc-api",
    "ports": [2022],
    "apiName": "trpc",
    "apiType": "trpc",
    "auth": "None",
    "computeType": "ServerlessApiGatewayRestApi",
    "integrationPattern": "isolated"
  },
  "targets": {
    "build": {
      "dependsOn": ["lint", "compile", "test", "bundle"]
    },
    "bundle": {
      "cache": true,
      "outputs": ["{workspaceRoot}/dist/{projectRoot}/bundle"],
      "executor": "nx:run-commands",
      "options": {
        "command": "rolldown -c rolldown.config.ts",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["compile"]
    },
    "compile": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}/tsc"],
      "options": {
        "command": "tsc --build tsconfig.lib.json",
        "cwd": "{projectRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "cache": true,
      "inputs": ["eslint"],
      "configurations": {
        "fix": {
          "fix": true
        },
        "skip-lint": {
          "force": true
        }
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["tsx --watch src/local-server.ts"],
        "cwd": "{projectRoot}"
      },
      "continuous": true
    },
    "serve-local": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["tsx --watch src/local-server.ts"],
        "cwd": "{projectRoot}",
        "env": {
          "SERVE_LOCAL": "true"
        }
      },
      "continuous": true
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{workspaceRoot}/coverage/{projectRoot}"
      }
    }
  }
}
