{
  "name": "@aws-nx-poc/common-constructs",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/common/constructs/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "dependsOn": [
        "lint",
        "compile",
        "test",
        "@aws-nx-poc/table-one:build",
        "@aws-nx-poc/table-two:build",
        "@aws-nx-poc/trpc:build",
        "@aws-nx-poc/smithy:build",
        "@aws-nx-poc/agents:build",
        "@aws-nx-poc/website:build"
      ]
    },
    "compile": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}/tsc"],
      "options": {
        "command": "tsc --build tsconfig.lib.json",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["generate:smithy-metadata"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "cache": true,
      "inputs": ["eslint"],
      "configurations": {
        "fix": {
          "fix": true
        },
        "skip-lint": {
          "force": true
        }
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{workspaceRoot}/coverage/{projectRoot}"
      }
    },
    "generate:smithy-metadata": {
      "cache": true,
      "executor": "nx:run-commands",
      "inputs": [
        {
          "dependentTasksOutputFiles": "**/*.json"
        }
      ],
      "outputs": [
        "{workspaceRoot}/packages/common/constructs/src/generated/smithy"
      ],
      "options": {
        "commands": [
          "nx g @aws/nx-plugin:open-api#ts-metadata --openApiSpecPath=\"dist/packages/smithy/model/build/openapi/openapi.json\" --outputPath=\"packages/common/constructs/src/generated/smithy\" --no-interactive"
        ]
      },
      "dependsOn": ["@aws-nx-poc/smithy-model:build"]
    }
  },
  "metadata": {
    "generator": "ts#project"
  }
}
